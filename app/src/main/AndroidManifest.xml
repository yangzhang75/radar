<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="Ship Radar"
        android:supportsRtl="false"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.ShipRadar">

        <!-- Real entry point: full HMI assembly (orchestrator-owned RadarScreen). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Standalone preview host for the PPI render surface (T2.1r); not a launcher. -->
        <activity
            android:name="com.shipradar.app.ppi.PpiDemoActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- 传感器数据模拟器(多 AIS/GPS/罗经/风/流/机舱),独立启动图标。 -->
        <activity
            android:name="com.shipradar.app.simulator.SimulatorActivity"
            android:exported="true"
            android:label="Radar 模拟器"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
